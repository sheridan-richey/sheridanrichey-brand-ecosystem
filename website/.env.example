# Sheridan Richey Brand Ecosystem - Environment Variables
# Copy this file to .env.local and fill in the actual values

# Website Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Sheridan Richey"
NEXT_PUBLIC_SITE_DESCRIPTION="Personal brand ecosystem for mid-career professionals seeking purpose and growth"

# Newsletter (Beehiiv) — required in production for /api/newsletter
BEEHIIV_API_KEY=your_beehiiv_api_key_here
BEEHIIV_PUBLICATION_ID=your_publication_id_here

# Contact form (Resend) — required in production for /api/contact
RESEND_API_KEY=re_your_resend_api_key_here
FROM_EMAIL=onboarding@yourdomain.com
TO_EMAIL=you@yourdomain.com

# Slack Integration - Optional for development
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_WORKSPACE_NAME="The ZAG Collective"

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=your_google_analytics_id_here

# Content Management (blog lives at repo root: ../content/blog)
CONTENT_DIR=../content

# Development Settings
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# Notes:
# - For local dev, NEXT_PUBLIC_* vars are enough for static pages.
# - Set BEEHIIV_* to test newsletter signup and lead magnets locally.
# - Set RESEND_* to test the contact form locally.
